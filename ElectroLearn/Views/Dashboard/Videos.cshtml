@model List<ElectroLearn.Models.Video>

@{
    ViewData["Title"] = "Curso - Videos";
    var firstVideo = Model?.FirstOrDefault();
    var cursoId = firstVideo?.CursoId ?? 0;
}

<style>
    body {
        background: url('/images/Robotica.jpg') no-repeat center center fixed;
        background-size: cover;
        color: white;
    }

        body::before {
            content: "";
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,0.6);
            z-index: -1;
        }

    /* 🔥 BOTÓN MISMO ESTILO */
    .toggle-btn {
        position: fixed;
        top: 18px;
        left: 18px;
        z-index: 2000;
        width: 42px;
        height: 42px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 18px;
        color: white;
        background: rgba(2, 6, 23, 0.85);
        border: 1px solid rgba(255,255,255,0.15);
        border-radius: 12px;
        cursor: pointer;
        transition: 0.25s ease;
    }

        .toggle-btn:hover {
            background: rgba(0, 198, 255, 0.25);
            transform: scale(1.08);
        }

    /* 🔥 SIDEBAR (UNIFICADO) */
    .sidebar {
        width: 240px;
        height: 100vh;
        position: fixed;
        top: 0;
        left: 0;
        background: rgba(2, 6, 23, 0.98);
        padding: 20px;
        padding-top: 70px;
        transition: transform 0.35s ease;
        z-index: 1500;
    }

        .sidebar.hidden {
            transform: translateX(-100%);
        }

        .sidebar h5 {
            color: #00c6ff;
            margin-bottom: 20px;
        }

    .menu a {
        display: block;
        padding: 12px 10px;
        margin-bottom: 6px;
        color: #cbd5e1;
        text-decoration: none;
        border-radius: 10px;
        transition: 0.2s;
    }

        .menu a:hover {
            background: rgba(0, 198, 255, 0.12);
            color: #00c6ff;
            padding-left: 14px;
        }

    /* 🔥 MAIN */
    .main {
        margin-left: 240px;
        transition: 0.35s ease;
    }

        .main.full {
            margin-left: 0;
        }

    /* 🔥 VIDEO UI */
    .video-grid {
        display: grid;
        grid-template-columns: 2fr 1fr;
        gap: 20px;
    }

    .video-player {
        background: rgba(30, 41, 59, 0.9);
        padding: 15px;
        border-radius: 15px;
    }

    iframe {
        width: 100%;
        height: 400px;
        border-radius: 10px;
    }

    .card-video {
        background: rgba(30, 41, 59, 0.9);
        border-radius: 12px;
        padding: 12px;
        margin-bottom: 10px;
        cursor: pointer;
        transition: 0.2s;
    }

        .card-video:hover {
            transform: scale(1.02);
            box-shadow: 0 0 10px #00c6ff;
        }

    .active {
        border: 2px solid #00c6ff;
    }

    @@media (max-width:768px) {
        .video-grid {
            grid-template-columns: 1fr;
        }
    }

    /* 🔥 LOGOUT */
    .logout {
        margin-top: 20px;
        display: block;
        color: #ff4b2b;
        text-decoration: none;
        font-weight: bold;
    }

        .logout:hover {
            color: #ff416c;
        }
</style>

<!-- 🔥 BOTÓN -->
<button class="toggle-btn" id="btnToggle" onclick="toggleSidebar()">☰</button>

<!-- 🔥 SIDEBAR -->
<div id="sidebar" class="sidebar">

    <h5>⚡ ElectroLearn</h5>

    <div class="menu">
        <a href="/Dashboard">🏠 Inicio</a>
        <a href="/Dashboard/MisCursos">📚 Mis cursos</a>
        <a href="/Dashboard/Videos">🎥 Videos</a>
        <a href="/Dashboard/Configuracion">⚙️ Configuración</a>
    </div>

    <!-- 🔥 CERRAR SESIÓN -->
    <a href="/Auth/Logout" class="logout">🚪 Cerrar sesión</a>

</div>

<!-- 🔥 CONTENIDO -->
<div id="mainContent" class="main container mt-4">

    <h2 class="fw-bold mb-4">🎓 Curso en Video</h2>

    @if (Context.Session.GetString("rol") == "Admin")
    {
        <button class="btn btn-warning mb-3"
                data-bs-toggle="modal"
                data-bs-target="#modalVideo">
            ➕ Agregar Video
        </button>
    }

    <div class="video-grid">

        <!-- PLAYER -->
        <div class="video-player">

            @if (firstVideo != null)
            {
                <iframe id="mainVideo" src="@firstVideo.YoutubeUrl" allowfullscreen></iframe>
                <h5 id="videoTitle" class="mt-3">@firstVideo.Titulo</h5>
            }
            else
            {
                <p>No hay videos aún 😢</p>
            }

        </div>

        <!-- LISTA -->
        <div>
            @foreach (var video in Model ?? new List<ElectroLearn.Models.Video>())
            {
                <div class="card-video @(video.Id == firstVideo?.Id ? "active" : "")"
                     onclick="changeVideo('@video.YoutubeUrl', '@video.Titulo', this)">
                    🎬 <strong>@video.Titulo</strong>
                </div>
            }
        </div>

    </div>
</div>

<!-- 🔥 MODAL -->
<div class="modal fade" id="modalVideo" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content bg-dark text-white">

            <form asp-controller="Video" asp-action="Crear" method="post">
                @Html.AntiForgeryToken()

                <div class="modal-header">
                    <h5 class="modal-title">➕ Agregar Video</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">

                    <input type="hidden" name="CursoId" value="@cursoId" />

                    <label>Título</label>
                    <input name="Titulo" class="form-control mb-2" required />

                    <label>YouTube URL</label>
                    <input name="YoutubeUrl" class="form-control mb-2" required />

                </div>

                <div class="modal-footer">
                    <button class="btn btn-success w-100">Guardar</button>
                </div>

            </form>

        </div>
    </div>
</div>

<script>
    function toggleSidebar() {
        const sidebar = document.getElementById("sidebar");
        const main = document.getElementById("mainContent");
        const btn = document.getElementById("btnToggle");

        sidebar.classList.toggle("hidden");
        main.classList.toggle("full");

        btn.innerHTML = sidebar.classList.contains("hidden") ? "☰" : "✖";
    }

    function changeVideo(url, title, el) {
        document.getElementById("mainVideo").src = url;
        document.getElementById("videoTitle").innerText = title;

        document.querySelectorAll(".card-video")
            .forEach(x => x.classList.remove("active"));

        el.classList.add("active");
    }
</script>