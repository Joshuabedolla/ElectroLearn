@model ElectroLearn.Models.ConfiguracionViewModel

@{
    ViewData["Title"] = "Configuración";
}

<style>
    body {
        margin: 0;
        padding: 0;
        font-family: Arial, sans-serif;
        background: url('/images/Robotica.jpg') no-repeat center center fixed;
        background-size: cover;
        overflow-x: hidden;
    }

    /* Overlay oscuro */
    .overlay {
        position: fixed;
        width: 100%;
        height: 100%;
        background: rgba(0,0,0,0.6);
        top: 0;
        left: 0;
        z-index: 0;
    }

    /* Contenedor principal */
    .config-box {
        position: relative;
        z-index: 2;
        max-width: 600px;
        margin: 80px auto;
        padding: 30px;
        background: rgba(255,255,255,0.1);
        backdrop-filter: blur(12px);
        border-radius: 20px;
        box-shadow: 0 0 25px rgba(0,0,0,0.4);
        color: white;
        animation: fadeIn 1s ease-in-out;
    }

    h2 {
        text-align: center;
        margin-bottom: 20px;
        animation: slideDown 1s ease;
    }

    label {
        font-weight: bold;
        margin-top: 10px;
        display: block;
    }

    input {
        width: 100%;
        padding: 10px;
        margin-top: 5px;
        margin-bottom: 15px;
        border: none;
        border-radius: 10px;
        outline: none;
        transition: 0.3s;
    }

        input:focus {
            transform: scale(1.03);
            box-shadow: 0 0 10px #00ffd5;
        }

    button {
        width: 100%;
        padding: 12px;
        border: none;
        border-radius: 12px;
        cursor: pointer;
        font-weight: bold;
        transition: 0.3s;
    }

    .btn-save {
        background: linear-gradient(90deg, #00c6ff, #0072ff);
        color: white;
    }

        .btn-save:hover {
            transform: scale(1.05);
            box-shadow: 0 0 15px #00c6ff;
        }

    .btn-pass {
        background: linear-gradient(90deg, #ff416c, #ff4b2b);
        color: white;
    }

        .btn-pass:hover {
            transform: scale(1.05);
            box-shadow: 0 0 15px #ff416c;
        }

    .alert {
        padding: 10px;
        margin-bottom: 15px;
        border-radius: 10px;
        text-align: center;
        animation: fadeIn 0.5s ease;
    }

    .alert-success {
        background: rgba(0,255,100,0.2);
    }

    .alert-danger {
        background: rgba(255,0,0,0.2);
    }

    /* Animaciones */
    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@keyframes slideDown {
        from {
            opacity: 0;
            transform: translateY(-30px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>

<div class="overlay"></div>

<div class="config-box">

    <h2>⚙️ Configuración</h2>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">
            @TempData["Success"]
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">
            @TempData["Error"]
        </div>
    }

    <input type="hidden" asp-for="Id" />

    <!-- PERFIL -->
    <form asp-action="GuardarPerfil" method="post">
        <label>Nombre</label>
        <input asp-for="Nombre" />

        <label>Email</label>
        <input asp-for="Email" />

        <button type="submit" class="btn-save">Guardar cambios</button>
    </form>

    <hr style="margin:20px 0; opacity:0.3;" />

    <!-- PASSWORD -->
    <form asp-action="CambiarPassword" method="post">
        <label>Contraseña actual</label>
        <input asp-for="PasswordActual" type="password" />

        <label>Nueva contraseña</label>
        <input asp-for="NuevaPassword" type="password" />

        <label>Confirmar contraseña</label>
        <input asp-for="ConfirmarPassword" type="password" />

        <button type="submit" class="btn-pass">Cambiar contraseña</button>
    </form>

</div>