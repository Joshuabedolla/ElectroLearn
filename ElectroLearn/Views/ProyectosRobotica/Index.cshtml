@model List<ElectroLearn.Controllers.ProyectosRoboticaController.Proyecto>

@{
    Layout = "_Layout"; // O el layout que uses
}

<style>
    body, html {
        height: 100%;
        margin: 0;
        font-family: 'Poppins', sans-serif;
        background: url('/images/Robotica.jpg') no-repeat center center fixed;
        background-size: cover;
        color: white;
    }

    .overlay {
        background: rgba(15, 23, 42, 0.85); /* fondo oscuro semi-transparente */
        min-height: 100vh;
        padding-top: 40px;
        padding-bottom: 40px;
    }

    .card {
        background: rgba(30, 41, 59, 0.9);
        border-radius: 15px;
        border: none;
        color: white;
        transition: transform 0.3s ease;
    }

        .card:hover {
            transform: translateY(-10px);
            box-shadow: 0 8px 20px rgba(0, 198, 255, 0.6);
        }

    video {
        border-radius: 15px;
        width: 100%;
        height: 200px;
        object-fit: cover;
    }

    h2 {
        text-align: center;
        margin-bottom: 30px;
        font-weight: 700;
        text-shadow: 0 0 8px #00c6ff;
    }
</style>

<div class="overlay">
    <div class="container">
        <h2>🤖 Proyectos de Robótica</h2>

        <div class="row g-4">
            @foreach (var proyecto in Model)
            {
                <div class="col-md-4">
                    <div class="card p-3 shadow">
                        <h5 class="card-title">@proyecto.Titulo</h5>
                        <video controls preload="metadata" poster="/images/video-placeholder.jpg">
                            <source src="@proyecto.VideoPath" type="video/mp4" />
                            Tu navegador no soporta la reproducción de video.
                        </video>
                    </div>
                </div>
            }
        </div>
    </div>
</div>