@model ElectroLearn.Models.Curso

@{
    var vistos = ViewBag.Vistos as List<int> ?? new List<int>();
}

<style>
    body {
        background: #0f172a;
        color: white;
    }

    .video-card {
        background: #1e293b;
        border-radius: 15px;
        padding: 15px;
        margin-bottom: 20px;
        transition: 0.3s;
    }

        .video-card:hover {
            transform: scale(1.01);
            box-shadow: 0 0 15px #00c6ff;
        }

    iframe {
        border-radius: 10px;
    }

    .badge {
        margin-left: 10px;
    }

    .btn-success {
        border-radius: 10px;
    }

    .empty {
        text-align: center;
        opacity: 0.7;
        margin-top: 40px;
    }
</style>

<div class="container mt-5">

    <a asp-controller="Curso" asp-action="Index" class="btn btn-secondary mb-3">
        ⬅ Volver
    </a>

    <h2>@Model?.Titulo</h2>
    <p>@Model?.Descripcion</p>

    <h4 class="mt-4">🎥 Videos</h4>

    @if (Model?.Videos != null && Model.Videos.Any())
    {
        foreach (var video in Model.Videos)
        {
            <div class="video-card">

                <h5>
                    @video.Titulo

                    @if (vistos.Contains(video.Id))
                    {
                        <span class="badge bg-success">✔ Visto</span>
                    }
                </h5>

                <!-- FIX: soporte seguro YouTube embed -->
                <iframe width="100%" height="350"
                        src="@video.YoutubeUrl"
                        allowfullscreen>
                </iframe>

                @if (!vistos.Contains(video.Id))
                {
                    <a asp-controller="Progreso"
                       asp-action="MarcarVisto"
                       asp-route-videoId="@video.Id"
                       class="btn btn-success mt-2">
                        ✔ Marcar como visto
                    </a>
                }

            </div>
        }
    }
    else
    {
        <div class="empty">
            <h4>Este curso aún no tiene videos 😢</h4>
        </div>
    }

</div>