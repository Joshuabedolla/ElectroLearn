@model ElectroLearn.Models.Curso

@{
    ViewData["Title"] = "Detalle del Curso";
}

<style>
    body {
        background: url('/images/Robotica.jpg') no-repeat center center fixed;
        background-size: cover;
        color: white;
    }

        body::before {
            content: "";
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,0.6);
            z-index: -1;
        }

    .toggle-btn {
        position: fixed;
        top: 18px;
        left: 18px;
        z-index: 2000;
        width: 42px;
        height: 42px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 18px;
        color: white;
        background: rgba(2, 6, 23, 0.85);
        border: 1px solid rgba(255,255,255,0.15);
        border-radius: 12px;
        cursor: pointer;
        transition: 0.25s ease;
    }

        .toggle-btn:hover {
            background: rgba(0, 198, 255, 0.25);
            transform: scale(1.08);
        }

    .sidebar {
        width: 240px;
        height: 100vh;
        position: fixed;
        top: 0;
        left: 0;
        background: rgba(2, 6, 23, 0.98);
        padding: 20px;
        padding-top: 70px;
        transition: transform 0.35s ease;
        z-index: 1500;
    }

        .sidebar.hidden {
            transform: translateX(-100%);
        }

        .sidebar h5 {
            color: #00c6ff;
            margin-bottom: 20px;
        }

    .menu a {
        display: block;
        padding: 12px 10px;
        margin-bottom: 6px;
        color: #cbd5e1;
        text-decoration: none;
        border-radius: 10px;
        transition: 0.2s;
    }

        .menu a:hover {
            background: rgba(0, 198, 255, 0.12);
            color: #00c6ff;
            padding-left: 14px;
        }

    .logout-link {
        margin-top: 15px;
        display: block;
        padding: 12px 10px;
        border-radius: 10px;
        color: #ff6b6b;
        text-decoration: none;
        transition: 0.2s;
    }

        .logout-link:hover {
            background: rgba(255,0,0,0.15);
            color: #ff3b3b;
            padding-left: 14px;
        }

    .main {
        margin-left: 240px;
        transition: 0.35s ease;
    }

        .main.full {
            margin-left: 0;
        }

    .curso-header {
        background: rgba(30, 41, 59, 0.9);
        padding: 20px;
        border-radius: 15px;
        margin-bottom: 25px;
    }

        .curso-header p {
            color: #cbd5e1;
        }

    .video-card {
        background: rgba(30, 41, 59, 0.9);
        border-radius: 15px;
        padding: 15px;
        transition: 0.2s;
    }

        .video-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 25px rgba(0,0,0,0.4);
        }

    iframe {
        border-radius: 10px;
    }

    .btn-glow {
        background: linear-gradient(45deg, #00c6ff, #0072ff);
        border: none;
        color: white;
        border-radius: 10px;
    }

        .btn-glow:hover {
            box-shadow: 0 0 10px #00c6ff;
            transform: scale(1.05);
        }
</style>

<button class="toggle-btn" id="btnToggle" onclick="toggleSidebar()">
    ☰
</button>

<div id="sidebar" class="sidebar">

    <h5>⚡ ElectroLearn</h5>

    <div class="menu">
        <a href="/Dashboard">🏠 Inicio</a>
        <a href="/Dashboard/MisCursos">📚 Mis cursos</a>
        <a href="/Dashboard/Videos">🎥 Videos</a>
        <a href="/Dashboard/Configuracion">⚙️ Configuración</a>

        <a href="/Auth/Logout" class="logout-link">🚪 Cerrar sesión</a>
    </div>

</div>

<div id="mainContent" class="main container mt-4">

    <a asp-action="Index" class="btn btn-secondary mb-3">
        ⬅ Volver
    </a>

    <div class="curso-header">
        <h2>📘 @Model.Titulo</h2>
        <p>@Model.Descripcion</p>

        <span class="badge bg-info text-dark">
            🎥 @(Model.Videos?.Count ?? 0) videos
        </span>
    </div>

    @if (Context.Session.GetString("rol") == "Admin")
    {
        <button class="btn btn-glow mb-3"
                data-bs-toggle="modal"
                data-bs-target="#modalVideo">
            ➕ Agregar Video
        </button>
    }

    @if (Model.Videos != null && Model.Videos.Any())
    {
        <div class="row g-4">

            @foreach (var video in Model.Videos)
            {
                <div class="col-md-6">

                    <div class="video-card">

                        <h5>@video.Titulo</h5>

                        <iframe width="100%" height="250"
                                src="@video.YoutubeUrl"
                                allowfullscreen>
                        </iframe>

                        @if (Context.Session.GetString("rol") == "Admin")
                        {
                            <div class="mt-3 d-flex gap-2">

                                <button type="button"
                                        class="btn btn-glow btn-sm w-100"
                                        data-bs-toggle="modal"
                                        data-bs-target="#modalEditVideo"
                                        onclick="setEdit(@video.Id,
                                        '@Html.Raw(video.Titulo.Replace("'", "\\'"))',
                                        '@video.YoutubeUrl')">
                                    ✏ Editar
                                </button>

                                <form asp-controller="Video"
                                      asp-action="Eliminar"
                                      method="post"
                                      class="w-100">

                                    @Html.AntiForgeryToken()

                                    <input type="hidden" name="id" value="@video.Id" />
                                    <input type="hidden" name="cursoId" value="@Model.Id" />

                                    <button type="submit"
                                            class="btn btn-glow btn-sm w-100">
                                        🗑 Eliminar
                                    </button>

                                </form>

                            </div>
                        }

                    </div>

                </div>
            }

        </div>
    }
    else
    {
        <div class="text-center mt-5">
            <h4>Este curso aún no tiene videos 😢</h4>
        </div>
    }

</div>

<!-- MODAL AGREGAR VIDEO -->
<div class="modal fade" id="modalVideo" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content bg-dark text-white">

            <div class="modal-header border-secondary">
                <h5 class="modal-title">➕ Agregar Video</h5>

                <button type="button"
                        class="btn-close btn-close-white"
                        data-bs-dismiss="modal">
                </button>
            </div>

            <form asp-controller="Video" asp-action="Crear" method="post">

                @Html.AntiForgeryToken()

                <div class="modal-body">

                    <input type="hidden" name="CursoId" value="@Model.Id" />

                    <div class="mb-3">
                        <label class="form-label">Título</label>

                        <input type="text"
                               name="Titulo"
                               class="form-control"
                               required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">URL de YouTube</label>

                        <input type="text"
                               name="YoutubeUrl"
                               class="form-control"
                               required />
                    </div>

                </div>

                <div class="modal-footer border-secondary">

                    <button type="button"
                            class="btn btn-secondary"
                            data-bs-dismiss="modal">
                        Cancelar
                    </button>

                    <button type="submit" class="btn btn-glow">
                        Guardar
                    </button>

                </div>

            </form>

        </div>
    </div>
</div>

<!-- MODAL EDITAR VIDEO -->
<div class="modal fade" id="modalEditVideo" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content bg-dark text-white">

            <div class="modal-header border-secondary">
                <h5 class="modal-title">✏ Editar Video</h5>

                <button type="button"
                        class="btn-close btn-close-white"
                        data-bs-dismiss="modal">
                </button>
            </div>

            <form asp-controller="Video"
                  asp-action="Editar"
                  method="post">

                @Html.AntiForgeryToken()

                <div class="modal-body">

                    <input type="hidden"
                           id="editId"
                           name="Id" />

                    <div class="mb-3">
                        <label class="form-label">Título</label>

                        <input type="text"
                               id="editTitulo"
                               name="Titulo"
                               class="form-control"
                               required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">URL de YouTube</label>

                        <input type="text"
                               id="editUrl"
                               name="YoutubeUrl"
                               class="form-control"
                               required />
                    </div>

                </div>

                <div class="modal-footer border-secondary">

                    <button type="button"
                            class="btn btn-secondary"
                            data-bs-dismiss="modal">
                        Cancelar
                    </button>

                    <button type="submit"
                            class="btn btn-glow">
                        Guardar cambios
                    </button>

                </div>

            </form>

        </div>
    </div>
</div>

<script>
    function setEdit(id, titulo, url) {
        document.getElementById("editId").value = id;
        document.getElementById("editTitulo").value = titulo;
        document.getElementById("editUrl").value = url;
    }

    function toggleSidebar() {
        const sidebar = document.getElementById("sidebar");
        const main = document.getElementById("mainContent");
        const btn = document.getElementById("btnToggle");

        sidebar.classList.toggle("hidden");
        main.classList.toggle("full");

        btn.innerHTML = sidebar.classList.contains("hidden") ? "☰" : "✖";
    }
</script>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>