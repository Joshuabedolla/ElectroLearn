@model ElectroLearn.Models.Video

@{
    ViewData["Title"] = "Agregar Video";
}

<style>
    body {
        background: linear-gradient(135deg, #0f172a, #020617);
        color: white;
    }

    .card-form {
        background: rgba(30,41,59,0.9);
        backdrop-filter: blur(10px);
        border-radius: 20px;
        padding: 30px;
        box-shadow: 0 0 25px rgba(0,198,255,0.2);
        animation: fadeIn 0.6s ease;
    }

    .btn-glow {
        background: linear-gradient(45deg, #00c6ff, #0072ff);
        border: none;
        color: white;
        border-radius: 12px;
        transition: 0.3s;
    }

        .btn-glow:hover {
            transform: scale(1.05);
            box-shadow: 0 0 12px #00c6ff;
        }

    input, select {
        border-radius: 10px !important;
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(15px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>

<div class="container mt-5" style="max-width:600px;">

    <div class="card-form">

        <h3 class="text-center mb-4">🎬 Agregar Video</h3>

        <form asp-controller="Video" asp-action="Crear" method="post">
            @Html.AntiForgeryToken()

            <!-- 🔥 IMPORTANTE: evitar ModelState vacío -->
            <input type="hidden" asp-for="CursoId" />

            <div class="mb-3">
                <label class="form-label">Título</label>
                <input asp-for="Titulo" class="form-control" />
                <span asp-validation-for="Titulo" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label class="form-label">URL de YouTube</label>
                <input asp-for="YoutubeUrl" class="form-control"
                       placeholder="https://youtube.com/watch?v=..." />
                <span asp-validation-for="YoutubeUrl" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label class="form-label">Curso</label>
                <select asp-for="CursoId"
                        class="form-control"
                        asp-items="ViewBag.Cursos">
                </select>
            </div>

            <button type="submit" class="btn btn-glow w-100">
                💾 Guardar Video
            </button>

        </form>

    </div>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}