@model List<Curso>

@{
    var usuario = Context.Session.GetString("usuario");
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Dashboard | ElectroLearn</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body {
            margin: 0;
            font-family: 'Poppins', sans-serif;
            background: #0f172a;
            color: white;
        }

        .sidebar {
            width: 250px;
            height: 100vh;
            background: #020617;
            position: fixed;
            padding: 20px;
        }

            .sidebar h3 {
                color: #00c6ff;
            }

            .sidebar a {
                display: block;
                color: #ccc;
                margin: 15px 0;
                text-decoration: none;
                transition: 0.3s;
            }

                .sidebar a:hover {
                    color: white;
                    padding-left: 5px;
                }

        .main {
            margin-left: 250px;
            padding: 30px;
        }

        .card-course {
            background: #1e293b;
            border-radius: 15px;
            padding: 20px;
            transition: 0.3s;
            height: 100%;
        }

            .card-course:hover {
                transform: translateY(-5px);
                background: #334155;
            }

        .btn-custom {
            background: linear-gradient(135deg, #0072ff, #00c6ff);
            border: none;
        }

            .btn-custom:hover {
                opacity: 0.9;
            }
    </style>
</head>

<body>

    <!-- SIDEBAR -->
    <div class="sidebar">
        <h3>🤖 ElectroLearn</h3>

        <p class="mt-3">👋 @usuario</p>

        <a href="#">🏠 Inicio</a>
        <a href="#">📚 Mis cursos</a>
        <a href="#">🎥 Videos</a>
        <a href="#">⚙️ Configuración</a>

        <!-- CORREGIDO -->
        <a href="/Auth/Logout">🚪 Cerrar sesión</a>
    </div>

    <!-- MAIN -->
    <div class="main">

        <h2 class="mb-4">Bienvenido 👋</h2>

        <div class="row">

            @if (Model != null && Model.Any())
            {
                @foreach (var curso in Model)
                {
                    <div class="col-md-4 mb-4">
                        <div class="card-course">
                            <h4>@curso.Titulo</h4>
                            <p>@curso.Descripcion</p>

                            <a href="/Curso/Detalle/@curso.Id" class="btn btn-custom w-100">
                                Ver curso
                            </a>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="text-center mt-5">
                    <h4>No hay cursos disponibles 😢</h4>
                    <p>Pronto agregaremos contenido</p>
                </div>
            }

        </div>

    </div>

</body>
</html>