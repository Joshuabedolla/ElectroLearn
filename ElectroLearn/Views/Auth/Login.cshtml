@model ElectroLearn.ViewModels.LoginViewModel

@{
    Layout = null;
}

<!DOCTYPE html>

<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>ElectroLearn | Login</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">

    <style>
        body {
            font-family: 'Poppins', sans-serif;
            background: url('/images/Robotica.jpg') no-repeat center center fixed;
            background-size: cover;
            height: 100vh;
        }

        /* Overlay oscuro */
        .overlay {
            background: rgba(15, 23, 42, 0.8);
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
        }

        .login-container {
            position: relative;
            z-index: 2;
        }

        .login-box {
            background: rgba(0, 0, 0, 0.75);
            backdrop-filter: blur(12px);
            padding: 45px;
            border-radius: 20px;
            width: 370px;
            color: white;
            box-shadow: 0 10px 40px rgba(0, 198, 255, 0.4);
            animation: fadeIn 1s ease;
        }

        @@keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(30px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .logo {
            font-size: 28px;
            font-weight: 600;
        }

        .subtitle {
            font-size: 14px;
            color: #cbd5f5;
            margin-bottom: 20px;
        }

        .form-control {
            border-radius: 12px;
            background: rgba(255,255,255,0.9);
            border: none;
            color: #222;
            height: 45px;
            transition: 0.3s;
        }

            .form-control::placeholder {
                color: #777;
            }

            .form-control:focus {
                box-shadow: 0 0 12px rgba(0,198,255,0.8);
                transform: scale(1.02);
            }

        .btn-custom {
            background: linear-gradient(135deg, #00c6ff, #0072ff);
            border: none;
            border-radius: 12px;
            padding: 10px;
            font-weight: 500;
            transition: 0.3s;
            color: white;
        }

            .btn-custom:hover {
                transform: translateY(-2px);
                box-shadow: 0 8px 20px rgba(0,198,255,0.6);
            }

        a {
            color: #38bdf8;
            text-decoration: none;
        }

            a:hover {
                color: #0ea5e9;
                text-decoration: underline;
            }

        .error {
            font-size: 13px;
        }

        /* ALERTA MODERNA */
        .login-alert {
            background: rgba(15, 23, 42, 0.85);
            border-left: 4px solid #00c6ff;
            color: white;
            padding: 14px 18px;
            border-radius: 14px;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 15px;
            font-weight: 500;
            backdrop-filter: blur(10px);
            box-shadow: 0 8px 25px rgba(0, 198, 255, 0.25);
            animation: slideDown 0.5s ease;
        }

            .login-alert .icon {
                font-size: 20px;
                color: #00c6ff;
            }

        @@keyframes slideDown {
            from {
                opacity: 0;
                transform: translateY(-15px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
    </style>

</head>

<body>

    <div class="overlay"></div>

    <div class="login-container d-flex justify-content-center align-items-center vh-100">

        <div class="login-box">

            <div class="text-center mb-4">
                <div class="logo">🤖 ElectroLearn</div>
                <div class="subtitle">Inicia sesión para continuar</div>
            </div>

            @if (TempData["Error"] != null)
            {
                <div class="login-alert">
                    <span class="icon">⚡</span>
                    <span>@TempData["Error"]</span>
                </div>
            }

            <form asp-controller="Auth" asp-action="Login" method="post">

                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>

                <div class="mb-3">
                    <input class="form-control" asp-for="Email" placeholder="📧 Correo electrónico" />
                    <span class="text-danger" asp-validation-for="Email"></span>
                </div>

                <div class="mb-3">
                    <input class="form-control" asp-for="Password" type="password" placeholder="🔒 Contraseña" />
                    <span class="text-danger" asp-validation-for="Password"></span>
                </div>

                <button class="btn btn-custom w-100" type="submit">
                    Entrar
                </button>

            </form>

            <p class="text-danger mt-3 text-center error">@ViewBag.Error</p>

            <div class="text-center mt-3">
                <small>¿No tienes cuenta?</small><br />
                <a href="/Auth/Registro">Crear cuenta</a>
            </div>

        </div>

    </div>

    <script src="https://cdn.jsdelivr.net/npm/jquery@3.6.0/dist/jquery.min.js"></script>

    <script src="https://cdn.jsdelivr.net/npm/jquery-validation@1.19.5/dist/jquery.validate.min.js"></script>

    <script src="https://cdn.jsdelivr.net/npm/jquery-validation-unobtrusive@3.2.13/dist/jquery.validate.unobtrusive.min.js"></script>

</body>
</html>

