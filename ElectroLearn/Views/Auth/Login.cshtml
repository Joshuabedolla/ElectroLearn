@model ElectroLearn.ViewModels.LoginViewModel

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>ElectroLearn | Login</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">

    <style>
        body {
            font-family: 'Poppins', sans-serif;
            background: linear-gradient(rgba(0,0,0,0.7), rgba(0,0,0,0.9)), url('/images/Robotica.jpg') no-repeat center;
            background-size: cover;
            height: 100vh;
            color: white;
        }

        .login-box {
            background: rgba(255, 255, 255, 0.05);
            backdrop-filter: blur(15px);
            padding: 45px;
            border-radius: 20px;
            width: 370px;
            transition: 0.3s ease;
        }

            .login-box:hover {
                transform: translateY(-5px);
            }

        .logo {
            font-size: 28px;
            font-weight: 600;
            letter-spacing: 1px;
        }

        .subtitle {
            font-size: 14px;
            color: #bbb;
            margin-bottom: 20px;
        }

        .form-control {
            border-radius: 12px;
            background: rgba(255,255,255,0.1);
            border: none;
            color: white;
        }

            .form-control::placeholder {
                color: #ccc;
            }

            .form-control:focus {
                box-shadow: none;
                background: rgba(255,255,255,0.15);
            }

        .btn-custom {
            background: linear-gradient(135deg, #0072ff, #00c6ff);
            border: none;
            border-radius: 12px;
            padding: 10px;
            font-weight: 500;
            transition: 0.3s;
        }

            .btn-custom:hover {
                transform: scale(1.03);
                opacity: 0.95;
            }

        a {
            text-decoration: none;
            font-size: 14px;
        }

            a:hover {
                text-decoration: underline;
            }

        .error {
            font-size: 13px;
        }
    </style>
</head>

<body>

    <div class="d-flex justify-content-center align-items-center vh-100">

        <div class="login-box shadow-lg">

            <div class="text-center mb-4">
                <div class="logo">🤖 ElectroLearn</div>
                <div class="subtitle">Plataforma de aprendizaje en electrónica</div>
            </div>

            <!-- Formulario con asp-for y validaciones -->
            <form asp-action="Login" method="post" novalidate>
                <div class="mb-3">
                    <input class="form-control" asp-for="Email" placeholder="Correo electrónico" />
                    <span class="text-danger" asp-validation-for="Email"></span>
                </div>

                <div class="mb-3">
                    <input class="form-control" asp-for="Password" type="password" placeholder="Contraseña" />
                    <span class="text-danger" asp-validation-for="Password"></span>
                </div>

                <button class="btn btn-custom w-100" type="submit">Entrar</button>
            </form>

            <p class="text-danger mt-3 text-center error">@ViewBag.Error</p>

            <div class="text-center mt-3">
                <a href="/Auth/Registro" style="color: #00c6ff;">Crear cuenta</a>
            </div>

        </div>

    </div>

    <!-- Scripts para validación Razor -->
    <script src="https://cdn.jsdelivr.net/npm/jquery@3.6.0/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation@1.19.5/dist/jquery.validate.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation-unobtrusive@3.2.13/dist/jquery.validate.unobtrusive.min.js"></script>

</body>
</html>