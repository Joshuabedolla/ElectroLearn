@model ElectroLearn.ViewModels.LoginViewModel

@{
    Layout = null;
}

<!DOCTYPE html>

<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>ElectroLearn | Login</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">


    <style>

        body {
            font-family: 'Poppins', sans-serif;
            background: url('/images/Robotica.jpg') no-repeat center center fixed;
            background-size: cover;
            height: 100dvh;
            max-height: 100dvh;
            overflow: hidden;
        }

        /* 🌑 OVERLAY */
        .overlay {
            background: rgba(15, 23, 42, 0.82);
            position: absolute;
            inset: 0;
            width: 100vw;
            height: 100vh;
        }

        /* 📦 CONTENEDOR */
        .login-container {
            position: relative;
            z-index: 2;
        }

        /* 💎 LOGIN BOX */
        .login-box {
            background: rgba(0, 0, 0, 0.72);
            backdrop-filter: blur(14px);
            padding: 45px;
            border-radius: 22px;
            width: 380px;
            color: white;
            box-shadow: 0 10px 40px rgba(0, 198, 255, 0.35);
            animation: fadeIn 0.8s ease;
            border: 1px solid rgba(255,255,255,0.08);
        }

        @@keyframes fadeIn {

            from {
                opacity: 0;
                transform: translateY(25px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* 🤖 LOGO */
        .logo {
            font-size: 30px;
            font-weight: 700;
            color: #00c6ff;
        }

        .subtitle {
            font-size: 14px;
            color: #cbd5f5;
            margin-top: 5px;
            margin-bottom: 22px;
        }

        /* ✏️ INPUTS */
        .form-control {
            border-radius: 14px;
            background: rgba(255,255,255,0.92);
            border: none;
            color: #222;
            height: 48px;
            transition: .3s;
            font-size: 14px;
        }

            .form-control::placeholder {
                color: #777;
            }

            .form-control:focus {
                box-shadow: 0 0 14px rgba(0,198,255,0.7);
                transform: scale(1.02);
            }

        /* 🔵 BOTÓN */
        .btn-custom {
            background: linear-gradient(135deg, #00c6ff, #0072ff);
            border: none;
            border-radius: 14px;
            padding: 11px;
            font-weight: 600;
            color: white;
            transition: .3s;
        }

            .btn-custom:hover {
                transform: translateY(-2px);
                box-shadow: 0 8px 22px rgba(0,198,255,0.55);
            }

        /* 🔗 LINKS */
        a {
            color: #38bdf8;
            text-decoration: none;
        }

            a:hover {
                color: #0ea5e9;
                text-decoration: underline;
            }

        .error {
            font-size: 13px;
        }

        /* 🚨 ALERTA MODERNA */
        .login-alert {
            position: relative;
            overflow: hidden;
            background: rgba(15, 23, 42, 0.94);
            border: 1px solid rgba(255,255,255,0.08);
            color: white;
            padding: 16px 18px;
            border-radius: 16px;
            margin-bottom: 22px;
            display: flex;
            align-items: center;
            gap: 14px;
            backdrop-filter: blur(14px);
            box-shadow: 0 10px 30px rgba(0,0,0,0.45);
            animation: slideDown 0.45s ease;
        }

        .alert-glow {
            position: absolute;
            inset: 0;
            background: linear-gradient( 90deg, transparent, rgba(0,198,255,0.08), transparent );
            animation: glowMove 2.5s linear infinite;
        }

        .alert-title {
            font-size: 15px;
            font-weight: 600;
            color: #00c6ff;
        }

        .alert-text {
            font-size: 14px;
            color: #e2e8f0;
        }

        .login-alert .icon {
            width: 45px;
            height: 45px;
            min-width: 45px;
            border-radius: 12px;
            background: rgba(0,198,255,0.12);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 22px;
            color: #00c6ff;
            z-index: 2;
        }

        @@keyframes slideDown {

            from {
                opacity: 0;
                transform: translateY(-15px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @@keyframes glowMove {

            0% {
                transform: translateX(-100%);
            }

            100% {
                transform: translateX(100%);
            }
        }
        @@media (max-width: 600px) { 
            .login-container {
                padding: 0;
                display: flex;
                flex-direction: column;
                justify-content: center;
                align-items: center;
            }
            .login-container {
                height: 80dvh;
                width: 90dvw;
                margin: auto;
            }
        }

    </style>

</head>

<body>

    <div class="overlay"></div>

    <div class="login-container d-flex justify-content-center align-items-center vh-100">

        <div class="login-box">

            <!-- 🤖 LOGO -->
            <div class="text-center mb-4">

                <div class="logo">
                    🤖 ElectroLearn
                </div>

                <div class="subtitle">
                    Inicia sesión para continuar
                </div>

            </div>

            <!-- 🚨 ALERTA -->
            @if (TempData["Error"] != null)
            {
                <div class="login-alert">

                    <div class="alert-glow"></div>

                    <span class="icon">
                        🔒
                    </span>

                    <div>

                        <div class="alert-title">
                            Acceso requerido
                        </div>

                        <div class="alert-text">
                            @TempData["Error"]
                        </div>

                    </div>

                </div>
            }

            @if (TempData["Success"] != null)
            {
                <div class="login-alert">

                    <div class="alert-glow"></div>

                    <div>                 

                        <div class="alert-text">
                            @TempData["Success"]
                        </div>

                    </div>

                </div>
            }

            <!-- 🔐 FORM -->
            <form asp-controller="Auth"
                  asp-action="Login"
                  method="post">

                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly"
                     class="text-danger mb-2">
                </div>

                <!-- EMAIL -->
                <div class="mb-3">

                    <input class="form-control"
                           asp-for="Email"
                           placeholder="📧 Correo electrónico" />

                    <span class="text-danger"
                          asp-validation-for="Email">
                    </span>

                </div>

                <!-- PASSWORD -->
                <div class="mb-3">

                    <input class="form-control"
                           asp-for="Password"
                           type="password"
                           placeholder="🔒 Contraseña" />

                    <span class="text-danger"
                          asp-validation-for="Password">
                    </span>

                </div>

                <!-- BOTÓN -->
                <button class="btn btn-custom w-100"
                        type="submit">

                    Entrar

                </button>

            </form>

            <!-- ERROR -->
            <p class="text-danger mt-3 text-center error">
                @ViewBag.Error
            </p>

            <!-- REGISTRO -->
            <div class="text-center mt-3">

                <small>
                    ¿No tienes cuenta?
                </small>

                <br />

                <a href="/Auth/Registro">
                    Crear cuenta
                </a>

            </div>

        </div>

    </div>

    <!-- SCRIPTS -->
    <script src="https://cdn.jsdelivr.net/npm/jquery@3.6.0/dist/jquery.min.js"></script>

    <script src="https://cdn.jsdelivr.net/npm/jquery-validation@1.19.5/dist/jquery.validate.min.js"></script>

    <script src="https://cdn.jsdelivr.net/npm/jquery-validation-unobtrusive@3.2.13/dist/jquery.validate.unobtrusive.min.js"></script>

</body>
</html>
