@model ElectroLearn.ViewModels.RegisterViewModel

@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <title>Registro ElectroLearn</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

    <style>
        body {
            background: url('/images/Robotica.jpg') no-repeat center center fixed;
            background-size: cover;
            height: 100vh;
            font-family: 'Poppins', sans-serif;
        }

        .register-box {
            background: rgba(0, 0, 0, 0.75);
            backdrop-filter: blur(10px);
            padding: 40px;
            border-radius: 15px;
            color: white;
            width: 350px;
            box-shadow: 0 0 15px rgba(0, 198, 255, 0.5);
        }

        .form-control {
            border-radius: 12px;
            background: white;
            border: none;
            color: #222;
            height: 45px;
            transition: box-shadow 0.3s ease;
        }

            .form-control::placeholder {
                color: #999;
            }

            .form-control:focus {
                background: white;
                color: #222;
                box-shadow: 0 0 10px rgba(0, 198, 255, 0.7);
                outline: none;
            }

        .btn-custom {
            background: white;
            color: #0072ff;
            font-weight: 600;
            border-radius: 12px;
            padding: 10px 0;
            border: none;
            transition: background-color 0.3s ease, color 0.3s ease;
            box-shadow: 0 4px 8px rgba(0, 198, 255, 0.3);
        }

            .btn-custom:hover {
                background: #0072ff;
                color: white;
                transform: translateY(-2px);
                opacity: 1;
                box-shadow: 0 6px 12px rgba(0, 198, 255, 0.6);
            }

        a {
            color: #00c6ff;
            transition: color 0.3s ease;
        }

            a:hover {
                color: #0072ff;
                text-decoration: none;
            }
    </style>
</head>

<body>

    <div class="d-flex justify-content-center align-items-center vh-100">

        <div class="register-box shadow-lg">
            <h2 class="text-center mb-4">🚀 Crear Cuenta</h2>

            @if (ViewBag.Error != null)
            {
                <p class="text-danger text-center">@ViewBag.Error</p>
            }

            <form asp-action="Registro" method="post" novalidate>
                <div class="mb-3">
                    <input class="form-control" asp-for="Nombre" placeholder="Nombre" />
                    <span class="text-danger" asp-validation-for="Nombre"></span>
                </div>

                <div class="mb-3">
                    <input class="form-control" asp-for="Email" type="email" placeholder="Correo electrónico" />
                    <span class="text-danger" asp-validation-for="Email"></span>
                </div>

                <div class="mb-3">
                    <input class="form-control" asp-for="Password" type="password" placeholder="Contraseña" />
                    <span class="text-danger" asp-validation-for="Password"></span>
                </div>

                <div class="mb-3">
                    <input class="form-control" asp-for="ConfirmPassword" type="password" placeholder="Confirmar contraseña" />
                    <span class="text-danger" asp-validation-for="ConfirmPassword"></span>
                </div>

                <button class="btn btn-custom w-100" type="submit">Registrarse</button>
            </form>

            <div class="text-center mt-3">
                <a href="/Auth/Login">¿Ya tienes cuenta? Inicia sesión</a>
            </div>
        </div>

    </div>

    <script src="https://cdn.jsdelivr.net/npm/jquery@3.6.0/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation@1.19.5/dist/jquery.validate.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation-unobtrusive@3.2.13/dist/jquery.validate.unobtrusive.min.js"></script>

</body>
</html>