@model ElectroLearn.ViewModels.RegisterViewModel

@{
    Layout = null;
}

<!DOCTYPE html>

<html>
<head>
    <title>Registro ElectroLearn</title>

    ```
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

    <style>
        body {
            background: url('/images/Robotica.jpg') no-repeat center center fixed;
            background-size: cover;
            height: 100vh;
            font-family: 'Poppins', sans-serif;
        }

        /* Capa oscura encima de la imagen */
        .overlay {
            background: rgba(15, 23, 42, 0.75);
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
        }

        .register-container {
            position: relative;
            z-index: 2;
        }

        .register-box {
            background: rgba(0, 0, 0, 0.75);
            backdrop-filter: blur(10px);
            padding: 40px;
            border-radius: 20px;
            color: white;
            width: 380px;
            box-shadow: 0 10px 40px rgba(0, 198, 255, 0.4);
            animation: fadeIn 1s ease;
        }

        @@keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(30px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .form-control {
            border-radius: 12px;
            background: rgba(255,255,255,0.9);
            border: none;
            height: 45px;
            transition: 0.3s;
        }

            .form-control:focus {
                box-shadow: 0 0 12px rgba(0,198,255,0.8);
                transform: scale(1.02);
            }

        .btn-custom {
            background: linear-gradient(135deg, #00c6ff, #0072ff);
            color: white;
            font-weight: 600;
            border-radius: 12px;
            padding: 10px;
            border: none;
            transition: 0.3s;
        }

            .btn-custom:hover {
                transform: translateY(-2px);
                box-shadow: 0 8px 20px rgba(0,198,255,0.6);
            }

        .logo {
            font-size: 26px;
            font-weight: bold;
            text-align: center;
            margin-bottom: 10px;
        }

        .subtitle {
            font-size: 14px;
            text-align: center;
            margin-bottom: 25px;
            color: #cbd5f5;
        }

        a {
            color: #38bdf8;
        }

            a:hover {
                color: #0ea5e9;
            }
    </style>
    ```

</head>

<body>

    <div class="overlay"></div>

    <div class="register-container d-flex justify-content-center align-items-center vh-100">

        ```
        <div class="register-box">

            <div class="logo">⚡ ElectroLearn</div>
            <div class="subtitle">Crea tu cuenta para empezar a aprender</div>

            <form asp-controller="Auth" asp-action="Registro" method="post">

                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>

                <div class="mb-3">
                    <input class="form-control" asp-for="Nombre" placeholder="👤 Nombre completo" />
                    <span class="text-danger" asp-validation-for="Nombre"></span>
                </div>

                <div class="mb-3">
                    <input class="form-control" asp-for="Email" placeholder="📧 Correo electrónico" />
                    <span class="text-danger" asp-validation-for="Email"></span>
                </div>

                <div class="mb-3">
                    <input class="form-control" asp-for="Password" type="password" placeholder="🔒 Contraseña" />
                    <span class="text-danger" asp-validation-for="Password"></span>
                </div>

                <div class="mb-3">
                    <input class="form-control" asp-for="ConfirmPassword" type="password" placeholder="🔁 Confirmar contraseña" />
                    <span class="text-danger" asp-validation-for="ConfirmPassword"></span>
                </div>

                <button class="btn btn-custom w-100" type="submit">
                    Crear cuenta
                </button>

            </form>

            <div class="text-center mt-3">
                <small>¿Ya tienes cuenta?</small><br />
                <a href="/Auth/Login">Inicia sesión aquí</a>
            </div>

        </div>
        ```

    </div>

    <script src="https://cdn.jsdelivr.net/npm/jquery@3.6.0/dist/jquery.min.js"></script>

    <script src="https://cdn.jsdelivr.net/npm/jquery-validation@1.19.5/dist/jquery.validate.min.js"></script>

    <script src="https://cdn.jsdelivr.net/npm/jquery-validation-unobtrusive@3.2.13/dist/jquery.validate.unobtrusive.min.js"></script>

</body>
</html>
