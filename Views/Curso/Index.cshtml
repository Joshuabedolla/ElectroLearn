@model List<ElectroLearn.Models.Curso>

@{
    ViewData["Title"] = "Mis Cursos";
    var openModal = ViewBag.OpenModal;


    var cursos = Model ?? new List<ElectroLearn.Models.Curso>();

    var usuario = Context.Session.GetString("usuario");
    var rol = Context.Session.GetString("rol");
}

@if (string.IsNullOrEmpty(usuario))
{
    <script>
        window.location.replace("/Auth/Login");
    </script>

    return;
}

