<div id="sidebar" class="sidebar">

    <h5>⚡ ElectroLearn</h5>

    <div class="menu">

        <a href="/Dashboard">🏠 Inicio</a>

        <a href="/Dashboard/MisCursos">📚 Mis cursos</a>

        <a href="/Dashboard/Videos">🎥 Videos</a>

        @if (rol == "Admin")
        {
            <a asp-controller="Curso"
               asp-action="Create">
                ➕ Agregar Curso
            </a>
        }

        <a href="/Dashboard/Configuracion">⚙️ Configuración</a>

        <a href="/Auth/Logout" class="logout-link">
            🚪 Cerrar sesión
        </a>

    </div>

</div>

<div id="mainContent" class="main">

    <div class="header-top">

        <div>
            <h2 class="fw-bold">
                📚 Mis Cursos
            </h2>

            <p class="text-light mb-0">
                Gestiona tus cursos y videos
            </p>
        </div>

    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info text-center p-4">
            <h5>No tienes cursos aún 😢</h5>
        </div>
    }
    else
    {
        <div class="row g-4">

            @foreach (var curso in Model)
            {
                <div class="col-lg-4 col-md-6 col-12">

                    <div class="card course-card h-100 border-0">

                        @if (!string.IsNullOrEmpty(curso.ImagenUrl))
                        {
                            <img src="@curso.ImagenUrl"
                                 class="card-img-top course-img" />
                        }

                        <div class="card-body">

                            <h5 class="fw-bold">
                                @curso.Titulo
                            </h5>

                            <p class="text-light small">
                                @curso.Descripcion
                            </p>

                            <span class="badge bg-info text-dark">
                                🎥 @(curso.Videos?.Count ?? 0) videos
                            </span>

                            @if (curso.Videos != null && curso.Videos.Any())
                            {
                                <div class="video-list">

                                    @foreach (var video in curso.Videos)
                                    {
                                        <div class="video-item">

                                            <div class="video-title">
                                                🎬 @video.Titulo
                                            </div>

                                            <div class="video-user">
                                                👤 Video agregado
                                            </div>

                                        </div>
                                    }

                                </div>
                            }

                        </div>

                        <div class="card-footer d-flex justify-content-between gap-2">

                            <a asp-controller="Curso"
                               asp-action="Details"
                               asp-route-id="@curso.Id"
                               class="btn btn-outline-light btn-sm">
                                Ver curso
                            </a>

                            <button onclick="limpiarModal('videoModal-@curso.Id')" class="btn btn-outline-success btn-sm"
                                    data-bs-toggle="modal"
                                    data-bs-target="#videoModal-@curso.Id">
                                ➕ Video
                            </button>

                        </div>

                    </div>

                </div>

