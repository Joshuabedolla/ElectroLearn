<body>

    @if (!string.IsNullOrEmpty(loginMessage))
    {
        <div class="alert alert-success alert-custom text-center">
            ✅ @loginMessage
        </div>
    }

    @if (!string.IsNullOrEmpty(welcomeMessage))
    {
        <div class="alert alert-info alert-custom text-center">
            👋 @welcomeMessage
        </div>
    }

    @if (!string.IsNullOrEmpty(logoutMessage))
    {
        <div class="alert alert-danger alert-custom text-center">
            🚪 @logoutMessage
        </div>
    }

    <button class="toggle-btn" id="btnToggle" onclick="toggleSidebar()">
        ☰
    </button>

    <div id="sidebar" class="sidebar">

        <div class="logo">⚡ ElectroLearn</div>

        <div class="user">@usuario</div>

        <div class="menu">
            <a asp-controller="Dashboard" asp-action="Index">🏠 Inicio</a>
            <a asp-controller="Dashboard" asp-action="MisCursos">📚 Mis cursos</a>
            <a asp-controller="Dashboard" asp-action="Videos">🎥 Videos</a>
            <a asp-controller="Dashboard" asp-action="Configuracion">⚙️ Configuración</a>
        </div>

        <a href="/Auth/Logout" class="logout">🚪 Cerrar sesión</a>

    </div>

    <div id="mainContent" class="main">

        <h2>Bienvenido, @usuario 👋</h2>

        <div class="row mt-4">

            @if (Model != null && Model.Any())
            {
                @foreach (var curso in Model)
                {
                    <div class="col-lg-4 col-md-6 col-12 mb-4">

                        <div class="card-course">

                            @if (!string.IsNullOrEmpty(curso.ImagenUrl))
                            {
                                <img src="@curso.ImagenUrl"
                                     class="course-img" />
                            }

                            <div class="card-content">

                                <h4>@curso.Titulo</h4>

                                <p>@curso.Descripcion</p>

                                <a class="btn btn-custom w-100 mt-2"
                                   href="/Curso/Details/@curso.Id">
                                    Ver curso
                                </a>

                            </div>

                        </div>

                    </div>
                }
            }
            else
            {
                <div class="text-center mt-5">
                    <h4>No hay cursos disponibles</h4>
                </div>
            }

        </div>

    </div>

    <script>

        function toggleSidebar() {

            const sidebar = document.getElementById("sidebar");
            const main = document.getElementById("mainContent");
            const btn = document.getElementById("btnToggle");

            sidebar.classList.toggle("hidden");
            main.classList.toggle("full");

            btn.innerHTML = sidebar.classList.contains("hidden")
                ? "☰"
                : "✖";
        }

        setTimeout(() => {

            const alerts = document.querySelectorAll(".alert-custom");

            alerts.forEach(alert => {

                alert.style.transition = "0.5s";
                alert.style.opacity = "0";

                setTimeout(() => {
                    alert.remove();
                }, 500);

            });

        }, 3000);

    </script>

</body>
</html>